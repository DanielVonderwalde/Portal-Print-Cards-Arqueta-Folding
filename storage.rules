rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Print card files
    match /printcards/{printCardId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 60 * 1024 * 1024  // Max 60MB
        && request.resource.contentType.matches('application/pdf|image/png|image/jpeg');
      allow delete: if request.auth != null;
    }

    // Signature images
    match /signatures/{signatureId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 1 * 1024 * 1024  // Max 1MB
        && request.resource.contentType.matches('image/png');
      allow delete: if false; // Signatures are immutable
    }

    // User avatars
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
