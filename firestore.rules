rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // DEMO MODE (currently active in the app, DEMO_MODE = true).
    // Open to ANY signed-in user, including anonymous. The app is
    // publicly accessible with no login in this mode.
    //
    // Before going to production: set DEMO_MODE = false in app.html
    // and restore the role-based rules (preserved in git history at
    // commit a8340bf and earlier — the isAdmin()/isDesigner() set).
    // ============================================================
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
